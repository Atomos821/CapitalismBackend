# ==========================================================
# CAPITALISM-DB - ENV CONFIGURATION
# ==========================================================

# --- PostgreSQL Configuration ---
# Admin user for the database
POSTGRES_USER=admin
# Secure password for the admin user
POSTGRES_PASSWORD=your_secure_password_here
# Name of the primary database
POSTGRES_DB=capitalism_db
# Port on which the database will be exposed on the host
DB_PORT=5432

# --- pgAdmin Configuration ---
# Default email to log into pgAdmin web interface
PGADMIN_DEFAULT_EMAIL=admin@capitalism.com
# Default password for pgAdmin web interface
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password_here
# Port on which pgAdmin will be accessible (http://localhost:5050)
PGADMIN_PORT=5050
